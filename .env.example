# ─────────────────────────────────────────────────────────────────────────────
# BotScan — Environment Configuration
# Copy this file to .env and fill in your values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
CORS_ORIGINS=*

# ── Instagram Provider ────────────────────────────────────────────────────────
# Options: mock | http | instaloader | apify | rapidapi
INSTAGRAM_PROVIDER=mock

# ── Apify (https://apify.com) ─────────────────────────────────────────────────
# Get your token at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# ── RapidAPI (https://rapidapi.com) ──────────────────────────────────────────
RAPIDAPI_KEY=
RAPIDAPI_HOST=instagram-scraper-api2.p.rapidapi.com

# ── Other Platform Providers ──────────────────────────────────────────────
# Options: mock | http | apify
TWITTER_PROVIDER=mock
FACEBOOK_PROVIDER=mock

# ── Cache & History ───────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600
HISTORY_MAX_SIZE=500
